---
import Sections from '../components/Sections.vue';

const items = [
  { name: 'Gallery', data: {} },
  { name: 'BioCardGrid', data: {} },
  { name: 'Itinerary', data: {} },
  { name: 'MediaGalleryGrid', data: {} },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Astro 6 hybrid build hash mismatch repro</title>
  </head>
  <body>
    <h1>Hybrid build hash mismatch repro</h1>
    <p>
      This page is prerendered. The Sections wrapper renders a
      Section dispatcher that uses a template-literal dynamic import
      to resolve to one of multiple section components. Each section
      uses dynamic import of glightbox at runtime. Mounted with
      <code>client:load</code> so the Server, Prerender and Client
      Vite passes all process the components and can produce
      divergent hash tables.
    </p>
    <Sections items={items} client:load />
  </body>
</html>
